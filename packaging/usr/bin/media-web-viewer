#!/bin/bash
# Media Web Viewer launcher
# Isolates the process from other python environments (Conda, etc.)
export PYTHONPATH=""
export PYTHONHOME=""

APP_DIR="/opt/media-web-viewer"
VENV_PYTHON="$APP_DIR/.venv/bin/python"

if [ ! -f "$VENV_PYTHON" ]; then
    echo "Fehler: Virtual environment nicht gefunden."
    echo "Bitte erneut installieren: sudo dpkg -i media-web-viewer_*.deb"
    exit 1
fi

# Run the app and log potential startup errors to /tmp
exec "$VENV_PYTHON" "$APP_DIR/main.py" "$@" > /tmp/media_viewer_startup.log 2>&1

# --- Media Web Viewer: Purified .gitignore ---

# 1. Broad Ignores
**/__pycache__/
*.pyc
*.so
.DS_Store
.idea/
.vscode/

# 2. Virtual Environments
.venv*/
**/venv/

# 3. Global Fragments (Recursive)
**/*.log
**/*.bak
**/*.tmp
**/*.swp
*.deb

# 4. Gated Purification (Whitelist approach)
# Step 4a: Ignore almost everything by default in root
/*

# Step 4b: Whitelist essential source directories (Source Only)
!/src/
!/infra/
!/scripts/
!/docs/
!/web/
!/tests/
!/logbuch/

# Step 4c: Re-ignore residues inside whitelisted directories (The "Deep Purge")
docs/html/
docs/latex/
media/**
!media/mock_files/
data/**
**/screenshots/
**/testing_screenshots/
**/reference_screenshots/
**/selenium_artifacts/
**/debug_artifacts/
**/*.log
**/*.png
**/*.jpg
**/*.jpeg

# Step 4d: Whitelist specific root files
!/.gitignore
!/README.md
!/VERSION
!/VERSION_SYNC.json
!/requirements*.txt
!/main.py
!/pyproject.toml
!/package.json

# Step 4e: Restore specific assets if needed
!/web/icons/**
!/web/images/**

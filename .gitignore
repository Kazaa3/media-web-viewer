# --- Media Web Viewer: Purified .gitignore ---
# Ignore selenium screenshots
tests/e2e/selenium/screenshots/

# Ignore selenium reference screenshots
tests/e2e/selenium/reference_screenshots/

# Referenz-Screenshots für Tests
/tests/reference_screenshots/
/logs/
/packages/

# 1. Broad Ignores
**/__pycache__/
*.pyc
*.so
.DS_Store
.idea/
.vscode/

# 2. Virtual Environments
.venv*/
**/venv/

# 3. Global Fragments (Recursive)
**/*.log
**/*.bak
**/*.tmp
**/*.swp
*.deb

# 4. Gated Purification (Whitelist approach)
# Step 4a: Ignore almost everything by default in root
/*

# Step 4b: Whitelist essential source directories
!/src/
!/infra/
!/scripts/
!/docs/
!/web/
!/tests/
!/logbuch/
!/media/
!/.github/

docs/latex/


# Step 4c: Re-ignore residues inside whitelisted directories
docs/html/
docs/latex/
media/**
!media/mock_files/

# Step 4d: Whitelist specific root files
!/.gitignore
!/README.md
!/VERSION
!/VERSION_SYNC.json
!/requirements*.txt
!/main.py
!/pyproject.toml
!/package.json

# 5. Tool-Specific
.pytest_cache/
.coverage
htmlcov/
geckodriver.log
chromedriver.log
ghostdriver.log
**/selenium_artifacts/
**/debug_artifacts/

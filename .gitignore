# ============================================================================
# Media Web Viewer - .gitignore
# ============================================================================

# --- Core Patterns ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# --- Virtual Environments ---
.venv/
.venv*/
venv/
env/
ENV/

# --- IDEs and Editors ---
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# --- Operating System ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Build & Distribution ---
build/
dist/
*.egg-info/
*.egg
*.whl
MANIFEST
*.spec
*.manifest
*.deb
*.deb.*
packaging/opt/
!packaging/opt/.gitkeep

# --- Project Specifics ---

# Data & Database
data/*
!data/.gitkeep
database.db
media_library.db

# Logs
logs/
*.log
*.log.*
data/logs/*
!data/logs/.gitkeep

# Temporary / Cache
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
.coverage.*
.env
.env.*
*.bak
*.tmp
*.temp
*~

# Screenshots & Local Assets
media/*
!media/.gitkeep
!media/README.md
media/.cache/
assets/generated/
screenshots/

# Test specific data and artifacts
tests/artifacts/
tests/assets/
tests/data/
tests/*.json
tests/*.png
tests/*.txt
tests/*.log
m4b_all_tools_results.json
m4b_mutagen_test_result
*.xz
*.json
database/
!tests/assets/.gitkeep
!tests/data/.gitkeep
!tests/README*.md
!tests/GUI_TEST_SUITE.md
!tests/TEST_ARTIFACTS.md
!tests/TEST_DOCUMENTATION.md

# GUI snapshots and screenshots (Bildschirmfotos)
testing_screenshots/
tests/selenium_artifacts/
tests/reference_screenshots/
tests/debug_*.png
*.png
*.jpg
*.jpeg
!web/assets/
!tests/assets/.gitkeep
docs/Screens/

# --- Folder Preservation Rules ---
# We keep these folders and their contents (unless matched above)
!src/
!web/
src/core/logs/
!infra/
!docs/
!scripts/
!tests/

# Keep root configuration files
!requirements.txt
!setup.py
!pyproject.toml
!README.md
!LICENSE.md
!VERSION
!TECH_STACK.md
!DEPENDENCIES.md
!DOCUMENTATION.md

# --- Documentation Subdirs ---
docs/html/
docs/latex/
docs/_build/
site/

# --- Remove old/legacy specific files ---
reinstall_deb.sh
performance_test.py
update_version.py
build_deb.sh
build_exe.sh
build_system.py
create_mocks.py
check_environment.py
VERSION_SYNC.json

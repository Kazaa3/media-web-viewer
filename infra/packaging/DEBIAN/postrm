#!/bin/bash
set -e

# Pass parameters to the script
# $1 is the action (purge, remove, upgrade, etc.)

APP_DIR="/opt/media-web-viewer"

if [ "$1" = "purge" ]; then
    echo "Purging Media Web Viewer data..."
    
    METADATA_FILE="$APP_DIR/.build_metadata"
    IS_DEV=0
    if [ -f "$METADATA_FILE" ]; then
        # Check if BRANCH is develop or milestone (case insensitive)
        if grep -qiE "BRANCH=(develop|milestone)" "$METADATA_FILE"; then
            IS_DEV=1
        fi
    fi

    if [ "$IS_DEV" = "1" ]; then
        echo "Development build detected. Preserving data/ directory for persistence."
        # Remove everything EXCEPT data/
        find "$APP_DIR" -mindepth 1 -maxdepth 1 ! -name "data" -exec rm -rf {} +
    else
        echo "Release build detected. Performing full wipe."
        if [ -d "$APP_DIR" ]; then
            rm -rf "$APP_DIR"
            echo "Removed $APP_DIR"
        fi
    fi
    
    # Remove launcher if it was installed by install_launcher.sh or similar
    if [ -f "/usr/local/bin/media-web-viewer" ]; then
        rm -f "/usr/local/bin/media-web-viewer"
    fi
fi

exit 0

{
  "version": "1.3.3",
  "sync_locations": [
    {
      "file": "main.py",
      "line_pattern": "VERSION = \"${version}\"  # Fallback",
      "description": "Python fallback version constant",
      "required": true
    },
    {
      "file": "packaging/DEBIAN/control",
      "line_pattern": "Version: ${version}",
      "description": "Debian package control file version",
      "required": true
    },
    {
      "file": "DOCUMENTATION.md",
      "line_pattern": "**Version:** ${version}",
      "description": "Documentation header version",
      "required": true
    },
    {
      "file": "DOCUMENTATION.md",
      "line_pattern": "${version}",
      "description": "Documentation version list entry",
      "required": true,
      "note": "Second occurrence in file"
    },
    {
      "file": "README.md",
      "line_pattern": "# Media Web Viewer (v${version})",
      "description": "README header version",
      "required": true
    },
    {
      "file": "README.md",
      "line_pattern": "sudo dpkg -i media-web-viewer_${version}_amd64.deb",
      "description": "README installation command example",
      "required": true
    },
    {
      "file": "packaging/usr/share/applications/media-web-viewer.desktop",
      "line_pattern": "Name=Media Web Viewer (v${version})",
      "description": "Linux start menu application name with version",
      "required": true
    },
    {
      "file": "DOCUMENTATION.md",
      "line_pattern": "Media Web Viewer (v${version})",
      "description": "Documentation architecture tree header",
      "required": false,
      "note": "Architecture section visual tree"
    },
    {
      "file": "DOCUMENTATION.md",
      "line_pattern": "SESSION MANAGEMENT TEST SUITE - v${version}",
      "description": "Test suite version display",
      "required": false,
      "note": "Dynamic test suite header"
    },
    {
      "file": "DOCUMENTATION.md",
      "line_pattern": "Building Debian Package (v${version})",
      "description": "Build output example header",
      "required": false,
      "note": "Build system documentation"
    },
    {
      "file": "DOCUMENTATION.md",
      "line_pattern": "**Current Version:** ${version}",
      "description": "Documentation current version reference",
      "required": false,
      "note": "End-of-document version reference"
    }
  ],
  "version_format": {
    "pattern": "^\\d+\\.\\d+\\.\\d+$",
    "description": "Semantic versioning: MAJOR.MINOR.PATCH"
  },
  "update_instructions": {
    "steps": [
      "1. Edit VERSION file with new version number",
      "2. Run: python tests/test_version_sync.py",
      "3. If test fails, update all locations listed in sync_locations",
      "4. Re-run test to verify all versions are synchronized"
    ],
    "automated_tool": "Future: Create update_version.py script to automate this"
  },
  "metadata": {
    "last_updated": "2026-03-08",
    "maintainer": "Media Web Viewer Team",
    "documentation": "See logbuch/53_Version_Synchronization_System.md"
  }
}
